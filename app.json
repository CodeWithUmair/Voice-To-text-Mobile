{
  "expo": {
    "name": "Voice to Text",
    "slug": "voice-to-text-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "com.umair.voicetotext",
      "versionCode": 2,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Voice to Text needs the microphone to transcribe your speech on-device.",
          "speechRecognitionPermission": "Voice to Text uses on-device speech recognition to convert your voice into text."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cb0ea22c-6aa0-4cd0-a77e-087ac9b24555"
      }
    }
  }
}
